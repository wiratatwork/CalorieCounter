# คัดลอกเป็น .env แล้วใส่ค่าจริง
# copy .env.example .env

# —— ฝั่งเบราว์เซอร์ / GitHub Pages (ใส่ใน GitHub Secrets ด้วยชื่อเดียวกัน) ——
SUPABASE_URL=
SUPABASE_ANON_KEY=

# —— E2E teardown (local + CI) ——
# ใช้ service role ถ้ามี; ไม่งั้น fallback เป็น anon key จากด้านบน
SUPABASE_SERVICE_ROLE_KEY=

# ตั้งเป็น 1 เมื่อ generate config สำหรับ Playwright (npm run env:e2e)
# E2E_MODE=1

# —— ฝั่ง Edge Function เท่านั้น (อย่าใส่ใน Pages)
# ตั้งบน Supabase:
#   npx supabase login
#   npx supabase link --project-ref <ref>
#   npx supabase secrets set GEMINI_API_KEY=... GEMINI_MODEL=gemini-3.1-flash-lite
#   npx supabase functions deploy estimate-calories
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
